<%- include("./partials/head", { title }) %>
<%- include("./partials/navbar") %>

<main class="flex min-h-screen items-center justify-center px-4 py-16 pt-28">
  <div class="w-full max-w-xl rounded-[2rem] border border-slate-200 bg-white p-8 text-center shadow-sm">
    <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-600">Error <%= statusCode %></p>
    <h1 class="mt-4 text-4xl font-extrabold text-slate-900"><%= title %></h1>
    <p class="mt-4 text-base text-slate-500"><%= message %></p>
    <a
      href="/boards"
      class="mt-8 inline-flex items-center justify-center rounded-2xl bg-sky-500 px-5 py-3 font-semibold text-white transition hover:bg-sky-600"
    >
      Go back to boards
    </a>
  </div>
</main>

<%- include("./partials/foot") %>
