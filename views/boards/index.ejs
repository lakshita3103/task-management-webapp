<%- include("../partials/head", { title }) %>
<%- include("../partials/navbar") %>

<main class="mx-auto max-w-7xl px-4 pb-10 pt-28 sm:px-6 lg:px-8">
  <section class="rounded-[2rem] border border-slate-200 bg-white px-5 py-6 shadow-sm sm:px-8">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-sky-600">Workspace overview</p>
        <h1 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">My Boards</h1>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-500 sm:text-base">
          Keep your planning space simple and visual. Create boards, open a board, and manage tasks across Trello-style columns below.
        </p>
      </div>

      <div class="flex w-full flex-col gap-3 sm:flex-row lg:max-w-xl">
        <label class="relative block flex-1">
          <span class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 3.473 9.766l3.63 3.631a.75.75 0 1 0 1.06-1.06l-3.63-3.63A5.5 5.5 0 0 0 9 3.5ZM5 9a4 4 0 1 1 8 0a4 4 0 0 1-8 0Z" clip-rule="evenodd" />
            </svg>
          </span>
          <input
            id="board-search"
            type="search"
            placeholder="Search boards by name"
            class="w-full rounded-2xl border border-slate-200 bg-slate-50 py-3 pl-11 pr-4 text-sm text-slate-700 outline-none transition focus:border-sky-400 focus:bg-white"
          />
        </label>

        <button
          id="toggle-board-form"
          type="button"
          class="inline-flex items-center justify-center rounded-2xl bg-sky-500 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-sky-600"
        >
          Create a New Board
        </button>
      </div>
    </div>

    <%- include("../partials/flash", { flash }) %>

    <section id="create-board-panel" class="mt-6 <%= boards.length ? 'hidden' : '' %> rounded-[1.75rem] border border-slate-200 bg-slate-50 p-5" data-board-form-panel>
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-lg font-semibold text-slate-900">Create a new board</h2>
          <p class="text-sm text-slate-500">Add a board name and an short description.</p>
        </div>
        <button
          type="button"
          class="self-start rounded-xl px-3 py-2 text-sm font-semibold text-slate-500 transition hover:bg-white hover:text-slate-800"
          data-close-board-form
        >
          Close
        </button>
      </div>

      <form action="/boards" method="POST" class="mt-5 grid gap-4 lg:grid-cols-[1.1fr_1fr_auto]">
        <input
          id="title"
          name="title"
          type="text"
          required
          maxlength="60"
          placeholder="Board name"
          class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-700 outline-none transition focus:border-sky-400"
        />
        <input
          id="description"
          name="description"
          type="text"
          maxlength="180"
          placeholder="Optional description"
          class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-700 outline-none transition focus:border-sky-400"
        />
        <button
          type="submit"
          class="inline-flex items-center justify-center rounded-2xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800"
        >
          Save board
        </button>
      </form>
    </section>
  </section>

  <section class="mt-8">
    <div class="mb-4 flex items-center justify-between">
      <div>
        <h2 class="text-xl font-bold text-slate-900">Boards</h2>
        <p class="text-sm text-slate-500">Choose a board to open its workspace.</p>
      </div>
      <span class="rounded-full bg-sky-100 px-4 py-2 text-sm font-semibold text-sky-700"><%= boards.length %> boards</span>
    </div>

    <% if (!boards.length) { %>
      <%- include("../partials/empty-state", {
        title: "No boards yet",
        message: "Use the Create New Board button above to build your first workspace."
      }) %>
    <% } else { %>
      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        <% boards.forEach((board) => { %>
          <article
            class="group rounded-[1.75rem] border border-slate-200 bg-white p-5 shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-lg"
            data-board-card
            data-board-title="<%= board.title.toLowerCase() %>"
          >
            <a href="/boards/<%= board._id %>" class="block">
              <div class="flex items-start justify-between gap-3">
                <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
                  Board
                </span>
                <% if (selectedBoard && selectedBoard._id.toString() === board._id.toString()) { %>
                  <span class="rounded-full bg-sky-100 px-3 py-1 text-xs font-semibold text-sky-700">Open</span>
                <% } %>
              </div>

              <h3 class="mt-5 text-lg font-bold text-slate-900 transition group-hover:text-sky-700"><%= board.title %></h3>
              <p class="mt-2 min-h-[48px] text-sm leading-6 text-slate-500">
                <%= board.description || "No description added yet. Open the board to start organizing lists and cards." %>
              </p>
              <div class="mt-5 flex items-center justify-between text-sm text-slate-400">
                <span><%= formatDate(board.createdAt) %></span>
                <span class="font-semibold text-slate-600">View board</span>
              </div>
            </a>

            <form action="/boards/<%= board._id %>?_method=DELETE" method="POST" class="mt-4 border-t border-slate-100 pt-4">
              <button
                type="submit"
                class="w-full rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-sm font-semibold text-rose-600 transition hover:bg-rose-100"
              >
                Delete board
              </button>
            </form>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>

  <section class="mt-10">
    <% if (!selectedBoard) { %>
      <%- include("../partials/empty-state", {
        title: "Open a board to see the kanban layout",
        message: "Once you select a board, its lists and tasks will appear here in Trello-style columns."
      }) %>
    <% } else { %>
      <div class="overflow-hidden rounded-[2rem] border border-slate-200 bg-[#dfe9f4] shadow-sm">
        <div class="border-b border-slate-200 bg-white px-5 py-5 sm:px-7">
          <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
            <div>
              <div class="flex items-center gap-3">
                <span class="rounded-full bg-sky-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-sky-700">
                  Active board
                </span>
                <span class="text-sm text-slate-400">Created <%= formatDate(selectedBoard.createdAt) %></span>
              </div>
              <h2 class="mt-3 text-2xl font-bold text-slate-900 sm:text-3xl"><%= selectedBoard.title %></h2>
              <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-500">
                <%= selectedBoard.description || "Use lists to group work and add cards under each list to track progress." %>
              </p>
            </div>

            <form action="/boards/<%= selectedBoard._id %>/lists" method="POST" class="grid gap-3 rounded-[1.5rem] border border-slate-200 bg-slate-50 p-4 sm:min-w-[360px]">
              <label for="list-title" class="text-sm font-semibold text-slate-700">Add a new column</label>
              <div class="flex flex-col gap-3 sm:flex-row">
                <input
                  id="list-title"
                  name="title"
                  type="text"
                  required
                  maxlength="60"
                  placeholder="Enter list title"
                  class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-700 outline-none transition focus:border-sky-400"
                />
                <button
                  type="submit"
                  class="rounded-2xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800"
                >
                  Add list
                </button>
              </div>
            </form>
          </div>
        </div>

        <div class="overflow-x-auto px-4 py-5 sm:px-6">
          <% if (!listsWithTasks.length) { %>
            <div class="min-w-full">
              <%- include("../partials/empty-state", {
                title: "No columns yet",
                message: "Create your first list above. Typical examples are To Do, In Progress, and Done."
              }) %>
            </div>
          <% } else { %>
            <div class="flex min-w-max gap-5 pb-2">
              <% listsWithTasks.forEach((list) => { %>
                <article class="w-[320px] shrink-0 rounded-[1.5rem] border border-slate-200 bg-[#f4f5f7] p-4 shadow-sm">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <h3 class="text-base font-bold text-slate-900"><%= list.title %></h3>
                      <p class="mt-1 text-sm text-slate-500"><%= list.tasks.length %> cards</p>
                    </div>
                    <form action="/boards/<%= selectedBoard._id %>/lists/<%= list._id %>?_method=DELETE" method="POST">
                      <button
                        type="submit"
                        class="rounded-xl px-3 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-slate-400 transition hover:bg-white hover:text-rose-500"
                      >
                        Remove
                      </button>
                    </form>
                  </div>

                  <div class="mt-4 space-y-3">
                    <% if (!list.tasks.length) { %>
                      <div class="rounded-2xl border border-dashed border-slate-300 bg-white/70 px-4 py-6 text-sm text-slate-500">
                        No cards in this list yet.
                      </div>
                    <% } %>

                    <% list.tasks.forEach((task) => { %>
                      <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:shadow-md">
                        <div class="flex items-start justify-between gap-3">
                          <div>
                            <span class="inline-flex rounded-full px-2.5 py-1 text-xs font-semibold <%= task.completed
                              ? 'bg-emerald-100 text-emerald-700'
                              : 'bg-amber-100 text-amber-700' %>">
                              <%= task.completed ? "Done" : "In Progress" %>
                            </span>
                            <h4 class="mt-3 text-base font-semibold text-slate-900"><%= task.title %></h4>
                          </div>
                          <span class="text-xs text-slate-400"><%= formatDate(task.createdAt) %></span>
                        </div>

                        <p class="mt-3 text-sm leading-6 text-slate-500">
                          <%= task.description || "No description provided for this card." %>
                        </p>

                        <div class="mt-4 flex items-center justify-between border-t border-slate-100 pt-4">
                          <form action="/lists/<%= list._id %>/tasks/<%= task._id %>?_method=PATCH" method="POST">
                            <input type="hidden" name="boardId" value="<%= selectedBoard._id %>" />
                            <button
                              type="submit"
                              class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-600 transition hover:border-sky-300 hover:bg-sky-50 hover:text-sky-700"
                            >
                              <%= task.completed ? "Edit status" : "Move forward" %>
                            </button>
                          </form>

                          <form action="/lists/<%= list._id %>/tasks/<%= task._id %>?_method=DELETE" method="POST">
                            <input type="hidden" name="boardId" value="<%= selectedBoard._id %>" />
                            <button
                              type="submit"
                              class="rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-sm font-semibold text-rose-600 transition hover:bg-rose-100"
                            >
                              Delete
                            </button>
                          </form>
                        </div>
                      </article>
                    <% }) %>
                  </div>

                  <form action="/lists/<%= list._id %>/tasks" method="POST" class="mt-4 rounded-2xl border border-dashed border-slate-300 bg-white/60 p-4">
                    <input type="hidden" name="boardId" value="<%= selectedBoard._id %>" />
                    <label class="text-sm font-semibold text-slate-700">Add new card</label>
                    <div class="mt-3 space-y-3">
                      <input
                        name="title"
                        type="text"
                        required
                        maxlength="80"
                        placeholder="Card title"
                        class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-700 outline-none transition focus:border-sky-400"
                      />
                      <textarea
                        name="description"
                        rows="3"
                        maxlength="240"
                        placeholder="Description"
                        class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-700 outline-none transition focus:border-sky-400"
                      ></textarea>
                      <button
                        type="submit"
                        class="w-full rounded-2xl bg-sky-500 px-4 py-3 text-sm font-semibold text-white transition hover:bg-sky-600"
                      >
                        Add task card
                      </button>
                    </div>
                  </form>
                </article>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    <% } %>
  </section>
</main>

<%- include("../partials/foot") %>
